{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "rune:fire_breath",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/particles"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 60,
				"max_particles": 120
			},
			"minecraft:emitter_lifetime_expression": {
				"activation_expression": 1,
				"expiration_expression": "v.emitter_age > 1.5"
			},
			"minecraft:emitter_shape_disc": {
				"offset": [
					"variable.dir_x * 1.5",
					1.5,
					"variable.dir_x == 0.0 && variable.dir_z == 0.0 ? 1.0 : variable.dir_z * 1.5"
				],
				"radius": "math.random(1, 5)",
				"plane_normal": "z",
				"direction": [
					"variable.dir_x",
					0,
					"variable.dir_x == 0.0 && variable.dir_z == 0.0 ? 1.0 : variable.dir_z"
				]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "math.random(0.8, 1.5)"
			},
			"minecraft:particle_initial_spin": {
				"rotation_rate": "math.random(-180, 180)"
			},
			"minecraft:particle_initial_speed": "math.random(10, 50)",
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [
					"math.random(-3, 3)",
					"math.random(-1, 2)",
					0
				],
				"linear_drag_coefficient": 2
			},
			"minecraft:particle_appearance_billboard": {
				"size": [
					"(0.4 + v.particle_age * 0.4) * (variable.scale == 0.0 ? 1.0 : variable.scale)",
					"(0.4 + v.particle_age * 0.4) * (variable.scale == 0.0 ? 1.0 : variable.scale)"
				],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 128,
					"texture_height": 128,
					"flipbook": {
						"base_UV": [
							0,
							24
						],
						"size_UV": [
							8,
							8
						],
						"step_UV": [
							8,
							0
						],
						"max_frame": 8,
						"stretch_to_lifetime": true
					}
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"interpolant": "v.particle_age / v.particle_lifetime",
					"gradient": {
						"0.0": "#FFFFFFFF",
						"0.4": "#FFFF6600",
						"1.0": "#00400000"
					}
				}
			}
		}
	}
}