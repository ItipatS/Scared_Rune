			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"gradient": {
						"0.0":  [1.0, 1.0, 0.5, 1.0],
						"0.3":  [1.0, 0.4, 0.0, 1.0],
						"0.7":  [0.8, 0.1, 0.0, 0.6],
