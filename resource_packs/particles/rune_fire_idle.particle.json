{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "rune:fire_idle",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/entity/attachable/rune_fire"
			}
		},
		"components": {
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 3,
				"max_particles": 6
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.8
			},
			"minecraft:emitter_shape_sphere": {
				"radius": 0.05,
				"direction": "outwards"
			},
			"minecraft:particle_initial_speed": 0.4,
			"minecraft:particle_motion_dynamic": {
				"linear_acceleration": [0, 2.5, 0],
				"linear_drag_coefficient": 0.5
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": "0.5 + v.particle_random_1 * 0.4"
			},
			"minecraft:particle_appearance_billboard": {
				"size": [
					"0.05 + v.particle_random_1 * 0.03",
					"0.05 + v.particle_random_1 * 0.03"
				],
				"facing_camera_type": "rotate_xyz",
				"uv": {
					"texture_width": 32,
					"texture_height": 32,
					"uv": [0, 0],
					"uv_size": [32, 32]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"gradient": {
						"0.0":  [1.0, 0.85, 0.1, 1.0],
						"0.5":  [1.0, 0.3,  0.0, 0.8],
						"1.0":  [0.4, 0.0,  0.0, 0.0]
					},
					"interpolant": "v.particle_age / v.particle_lifetime"
				}
			}
		}
	}
}
