{
	"format_version": "1.10.0",
	"minecraft:attachable": {
		"description": {
			"identifier": "rune:fire",
			"render_controllers": ["controller.render.item_default"],
			"materials": {
				"default": "entity_alphatest",
				"enchanted": "entity_alphatest_glint"
			},
			"textures": {
				"default": "textures/entity/attachable/rune_fire",
				"enchanted": "textures/misc/enchanted_item_glint"
			},
			"geometry": {
				"default": "geometry.rune"
			},
			"particle_effects": {
				"rune_held": "rune:fire_held"
			},
			"animations": {
				"first_person_hold": "animation.rune.first_person_hold",
				"third_person_hold": "animation.rune.third_person_hold",
				"held_particles":    "animation.rune.held_particles",
				"use_particles":     "animation.rune.use_particles"
			},
			"scripts": {
				"animate": [
					{ "first_person_hold": "c.is_first_person" },
					{ "third_person_hold": "!c.is_first_person" },
					"held_particles",
					{ "use_particles": "q.main_hand_item_use_duration > 0" }
				]
			}
		}
	}
}
